# Copy this file to .env and fill in your values.
# The .env file is gitignored and must NEVER be committed.

# ── OpenAI API (required for real-model experiments) ──────────────────────────
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the API base URL (e.g. for Azure OpenAI or a local proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── HuggingFace (optional; speeds up dataset downloads) ───────────────────────
# Obtain from https://huggingface.co/settings/tokens
# HF_TOKEN=hf_...

# ── Notes ─────────────────────────────────────────────────────────────────────
# All experiments that use the dummy model (correct_prob / seed config) run
# fully offline without any API key.  Only "real_llm" experiments need
# OPENAI_API_KEY.  See REPRODUCIBILITY.md for the offline-first quick-start.
